# Slack bot token (xoxb-...) with chat:write and im:write OAuth scopes
# Create a Slack app at https://api.slack.com/apps → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-token-here

# Your Slack user ID for DMs (e.g. U012AB3CD)
# Find it: Slack → click your profile → ⋮ → Copy member ID
SLACK_USER_ID=U012AB3CD

# Google Play app package name (e.g. care.freed.ifree)
PLAY_STORE_APP_ID=care.freed.ifree
